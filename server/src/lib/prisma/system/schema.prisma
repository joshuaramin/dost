generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id String @id @default(cuid())
  email   String @unique @db.VarChar(255)

  is_deleted Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp()

  Profile Profile?

  role_id String?
  role    Role?   @relation(fields: [role_id], references: [role_id])

  ActivityLog   ActivityLog[]
  DeviceSession DeviceSession[]

  @@index([role_id])
  @@index([is_deleted])
  @@index([created_at])
}

model Profile {
  profile_id String @id @default(cuid())
  first_name String
  last_name  String

  is_deleted Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp()

  User    User   @relation(fields: [user_id], references: [user_id])
  user_id String @unique
}

model Resource {
  resource_id String  @id @default(cuid())
  name        String  @unique @db.VarChar(100)
  slug        String  @unique
  order       Int
  parent_id   String?

  parent   Resource?  @relation("ResourceHeirarchy", fields: [parent_id], references: [resource_id])
  children Resource[] @relation("ResourceHeirarchy")

  is_deleted Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp()

  permissions Permission[]

  @@index([is_deleted])
  @@index([created_at])
}

model Role {
  role_id     String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  slug        String
  description String?  @db.Text
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamp()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamp()

  rolePermissions RolePermission[]
  users           User[]

  @@index([is_deleted])
  @@index([created_at])
}

model Permission {
  permission_id String @id @default(cuid())
  name          String @db.VarChar(100)
  slug          String

  is_deleted Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp()

  resource        Resource?        @relation(fields: [resource_id], references: [resource_id])
  resource_id     String?
  rolePermissions RolePermission[]

  @@index([is_deleted])
  @@index([created_at])
}

model RolePermission {
  role_permission_id String @id @default(cuid())

  role    Role   @relation(fields: [role_id], references: [role_id])
  role_id String

  Permission    Permission @relation(fields: [permission_id], references: [permission_id])
  permission_id String

  @@unique([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
}

model ActivityLog {
  activity_logs_id String   @id @default(cuid())
  type             String   @db.VarChar(50)
  decription       String?  @db.VarChar(100)
  is_deleted       Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamp()
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamp()
  user             User?    @relation(fields: [user_id], references: [user_id])
  user_id          String?
}

model DeviceSession {
  device_sessions_id String   @id @default(cuid())
  device_name        String   @db.VarChar(100)
  device_type        String
  os                 String
  browser            String
  user_agent         String
  ip_address         String   @db.VarChar(100)
  expired_at         DateTime
  is_deleted         Boolean  @default(false) @db.Boolean
  is_revoked         Boolean  @default(false) @db.Boolean
  created_at         DateTime @default(now()) @db.Timestamp()
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamp()

  user    User?   @relation(fields: [user_id], references: [user_id])
  user_id String?
}
